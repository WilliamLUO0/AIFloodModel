            hostname
            echo $CUDA_VISIBLE_DEVICES
            nvidia-smi -L
            ${CYLC_WORKFLOW_RUN_DIR}/bin/BG_Flood_Mahuika ${OUTFOLDER}${BGPARAM_COARSE}
        """
        [[[directives]]]
             --time=24:00:00

    [[Run_BG_fine_MilanSlice]]
        inherit = MilanSlice_BG
        execution time limit = PT72H
        script ="""
            ${CYLC_WORKFLOW_RUN_DIR}/bin/BG_Flood_Mahuika ${OUTFOLDER}${BGPARAM_THIN}
        """
        [[[directives]]]
             --time=72:00:00




    [[PlotFlood]]
        inherit = Maui_Anc_prepost
        env-script="""
            #module load GMT/5.4.5-GCC-7.1.0
            module load GMT/6.4.0-GCC-7.1.0
        """

        script="""
            regionplot=`awk '{if(NR==1){split($1,r,",");printf("%2.2f/%2.2f/%2.2f/%2.2f",r[1],r[2],r[3],r[4])}}' $INFOFILE`
            cd $CYLC_WORKFLOW_RUN_DIR/bin
            Plot_flood $INFOFILE $BGOUTFILE
        """



    [[sanity_checks]]
        inherit = Maui_Anc_prepost

        env-script="""
             module purge
             module load slurm NeSI
             module load Anaconda3
        """
        script="""
               set +eu
               source $(conda info --base)/etc/profile.d/conda.sh
               conda activate /nesi/project/niwa03440/conda/envs/geocat

               # Create sanity_checks_input.txt
               if [[ ! -d ${OUTFOLDER}sanity_checks ]]; then
                  mkdir ${OUTFOLDER}sanity_checks
               fi


               v1=hmax # Hmax
               out1=5 # v1 outlier definition (plot when value is exceeded)
               v2=Fr # Fr
               out2=5 # v2 outlier definition (plot when value is exceeded)
               # sanity_checks_input.txt
               #


               # initial time, initial layer, initial variable, no of variables to analysis, variable to analyse, outlier upper criteria
               # ie '0\n0\n0\n2\nhmax\n5\nzmax\n100\n' will analyse the hmax variable with an outlier limit of 5 and zmax with an outlier limit of 100
               printf '0\n0\n0\n1\nhmax\n5\n' > ${OUTFOLDER}sanity_checks/sanity_checks_input.txt

               GeoFabricsF=${GEOFABRICFILE%?z}


               # Plot boxplots
               python ${PYTHONPATH}sanity_checks.py ${BGOUTFILE}_coarse.nc ${BGOUTFILE}.nc $GeoFabricsF ${OUTFOLDER}sanity_checks_input.txt ${OUTFOLDER}sanity_checks 1 0 0


               # Plot histograms
               python ${PYTHONPATH}sanity_checks.py ${BGOUTFILE}_coarse.nc ${BGOUTFILE}.nc $GeoFabricsF ${OUTFOLDER}sanity_checks_input.txt ${OUTFOLDER}sanity_checks 0 1 0

               # Plot outliers
               while [[ -f ${OUTFOLDER}sanity_checks/sanity_checks_input.txt ]];
               do
                    python ${PYTHONPATH}sanity_checks.py ${BGOUTFILE}_coarse.nc ${BGOUTFILE}.nc $GeoFabricsF ${OUTFOLDER}sanity_checks/sanity_checks_input.txt ${OUTFOLDER}sanity_checks 0 0 1
               done

             # Plot boxplots
             #printf "0\n0\n0\n2\n$v1\n$out1\n$v2\n$out2\n" > ${OUTFOLDER}sanity_checks/sanity_checks_input.txt
             #while [[ -f ${OUTFOLDER}sanity_checks/sanity_checks_input.txt ]];
