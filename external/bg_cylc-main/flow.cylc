##BG_Flood run on new NIWA GPU on Milan, only a slice of it (1/8th). Somehow the export for Milan is not sufficient for compiling so here we enfore compile of Milan to happen in the Mahuika context

    [[Compile_BG_MilanSlice]]
        inherit = Milan_Compile_BG

        script ="""
            git clone --depth 1 --branch {{inputs.BGFLOOD_TAG}} https://github.com/CyprienBosserelle/BG_Flood.git
            cd ./BG_Flood/
            make
            cp BG_Flood ${CYLC_WORKFLOW_RUN_DIR}/bin/BG_Flood_Mahuika
