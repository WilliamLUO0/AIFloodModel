             --cluster=maui_ancil
             --gpus-per-node=A100:1
             --partition=niwa_work
             --account=niwap03440
             --ntasks=1
             --cpus-per-task=2
             --mem=80GB

     [[MilanSlice_BG]]
       platform = maui-cs-slurm
       env-script="""
            export PATH=/opt/nesi/CS400_centos7_bdw/XALT/current/bin:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/nvvm/bin:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/bin:/opt/nesi/CS400_centos7_bdw/netCDF/4.7.3-gimpi-2020a/bin:/opt/nesi/CS400_centos7_bdw/PCRE/8.43-GCCcore-9.2.0/bin:/opt/nesi/CS400_centos7_bdw/cURL/7.64.0-GCCcore-9.2.0/bin:/opt/nesi/CS400_centos7_bdw/HDF5/1.10.5-gimpi-2020a/bin:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/libfabric/bin:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/bin:/opt/nesi/CS400_centos7_bdw/binutils/2.32-GCCcore-9.2.0/bin:/opt/nesi/CS400_centos7_bdw/GCCcore/9.2.0/bin:$PATH
            export LD_LIBRARY_PATH=/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/nvvm/lib64:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/extras/CUPTI/lib64:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/lib64:/opt/nesi/CS400_centos7_bdw/netCDF/4.7.3-gimpi-2020a/lib64:/opt/nesi/CS400_centos7_bdw/PCRE/8.43-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/cURL/7.64.0-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/HDF5/1.10.5-gimpi-2020a/lib:/opt/nesi/CS400_centos7_bdw/Szip/2.1.1-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/libfabric/lib:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/lib:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/lib/release:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/lib/release_mt:/opt/nesi/CS400_centos7_bdw/binutils/2.32-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/zlib/1.2.11-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/GCCcore/9.2.0/lib64:/opt/nesi/CS400_centos7_bdw/GCCcore/9.2.0/lib


            export CUDA_VISIBLE_DEVICES=$(nvidia-smi -L | grep "Device  $((${CUDA_VISIBLE_DEVICES}-3))" | grep -o "MIG-[-a-z0-9]*")
       """
       [[[directives]]]
             --cluster=maui_ancil
             --gpus-per-node=nvidia_a100_1g.10gb:1
             --partition=niwa_work
             --account=niwap03440
             --ntasks=1
             --cpus-per-task=2
             --mem=10GB

     [[Milan_Compile_BG]]
       inherit = Maui_Anc_prepost
       env-script="""
            export PATH=/opt/nesi/CS400_centos7_bdw/XALT/current/bin:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/nvvm/bin:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/bin:/opt/nesi/CS400_centos7_bdw/netCDF/4.7.3-gimpi-2020a/bin:/opt/nesi/CS400_centos7_bdw/PCRE/8.43-GCCcore-9.2.0/bin:/opt/nesi/CS400_centos7_bdw/cURL/7.64.0-GCCcore-9.2.0/bin:/opt/nesi/CS400_centos7_bdw/HDF5/1.10.5-gimpi-2020a/bin:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/libfabric/bin:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/bin:/opt/nesi/CS400_centos7_bdw/binutils/2.32-GCCcore-9.2.0/bin:/opt/nesi/CS400_centos7_bdw/GCCcore/9.2.0/bin:$PATH
            export LD_LIBRARY_PATH=/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/nvvm/lib64:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/extras/CUPTI/lib64:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/lib64:/opt/nesi/CS400_centos7_bdw/netCDF/4.7.3-gimpi-2020a/lib64:/opt/nesi/CS400_centos7_bdw/PCRE/8.43-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/cURL/7.64.0-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/HDF5/1.10.5-gimpi-2020a/lib:/opt/nesi/CS400_centos7_bdw/Szip/2.1.1-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/libfabric/lib:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/lib:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/lib/release:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/lib/release_mt:/opt/nesi/CS400_centos7_bdw/binutils/2.32-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/zlib/1.2.11-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/GCCcore/9.2.0/lib64:/opt/nesi/CS400_centos7_bdw/GCCcore/9.2.0/lib

       """

     [[Python_conda]]
       inherit = Maui_Anc_prepost
       pre-script = """
             set +u
             module load Miniforge3
             source $(conda info --base)/etc/profile.d/conda.sh
             conda activate /nesi/project/niwa03440/conda/envs/geofabrics
             set -u
       """


    [[read_gpkg]]
    ## Read the gpkg file to extract domains, injection rids ...
        inherit = Python_conda

        script="""
            ## Flood domain
            python ${PYTHONPATH}ReadGPKG_cylc.py ${GEOPACKAGE} ${BGFLOODDOMAIN} flood $LOCATION geometry
            ## Rain domain
            python ${PYTHONPATH}ReadGPKG_cylc.py ${GEOPACKAGE} ${RAINMASK} rain $LOCATION geometry
            ## Domain (for refinement)
            python ${PYTHONPATH}ReadGPKG_cylc.py ${GEOPACKAGE} ${DOMAINMASK} domain $LOCATION geometry
            ## Oceanrids
            python ${PYTHONPATH}ReadGPKG_cylc.py ${GEOPACKAGE} ${CYLC_WORKFLOW_RUN_DIR}/oceanrids.txt basin $LOCATION rec2term
            ## Injectionrids
            python ${PYTHONPATH}ReadGPKG_cylc.py ${GEOPACKAGE} $INJECTION domain $LOCATION injection
            ## EVA_RIDS
            python ${PYTHONPATH}ReadGPKG_cylc.py ${GEOPACKAGE} ${CYLC_WORKFLOW_RUN_DIR}/EVA_rids.txt crude $LOCATION eva_rec2s

            ## OUTLET
            python ${PYTHONPATH}ReadGPKG_cylc.py ${GEOPACKAGE} ${CYLC_WORKFLOW_RUN_DIR}/Outlet_rids.txt crude $LOCATION outlets
        """


    [[prep_rain]]
        inherit = Maui_Anc_prepost
        script="""
            module load GMT/5.4.5-GCC-7.1.0
            module load NCO/4.7.5-GCC-7.1.0

            #cp ${RAINMASK} rainmask.json

            ogr2ogr -f "OGR_GMT" ${CYLC_WORKFLOW_RUN_DIR}/rainmask.gmt ${RAINMASK}

            REFTIME=`awk '{if(NR==2){print($0)}}' ${CYLC_WORKFLOW_RUN_DIR}/reftime.txt`

            MaskRain $RAININ ${CYLC_WORKFLOW_RUN_DIR}/rainmask.gmt $RAINOUT ${REFTIME}
        """

    [[prep_raintime]]
        inherit = Maui_Anc_JULIA

        script ="""

	       julia --project=${JULIAPROJ} -e "include(\"${CYLC_WORKFLOW_RUN_DIR}/bin/BG_cylc/src/gettide.jl\"); Puttimeatt(ARGS[1],ARGS[2])" $RAINOUT ${CYLC_WORKFLOW_RUN_DIR}/reftime.txt
        """
    [[prep_roughness]]
        inherit = Maui_Anc_GMT

        script="""
            gmt grdmath ${ROUGHNESSFILE} 0.04 DENAN 0.01 MAX = ${CYLC_WORKFLOW_RUN_DIR}/Roughness.nc?zo
        """


    [[prep_elevation]]
        inherit = Maui_Anc_GMT

        script="""
            gmt grdmath ${GEOFABRICFILE}?z -50.0 DENAN -50.0 MAX = ${DEMFILE}?z
            #gmt grdsample ${BATHTYFIX} -R${GEOFABRICFILE}?z -Gbathyfix_bathyonly.nc
            #gmt grdmath ${GEOFABRICFILE}?data_source 2 NEQ 0 NAN ${GEOFABRICFILE}?z MUL bathyfix_bathyonly.nc DENAN -50.0 DENAN -50.0 MAX = ${CYLC_WORKFLOW_RUN_DIR}/Elevation.nc?z
        """



    [[prep_injection]]
        inherit = Maui_Anc_GMT

        script="""
            {% if GEOPACKAGE is defined and GEOPACKAGE|length %}

            ogr2ogr -f "OGR_GMT" ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt ${DOMAIN}
            #grep @D ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt | sed 's/# @D//g' | awk 'BEGIN{FS=",";RS="|"}{if(NR==5){print($0)}}' | awk 'BEGIN{RS=","}{print($1)}' >  ${INJECTION}

            {% endif %}
        """


    [[Get_injectionXY]]
       inherit = Maui_Anc_JULIA

        script="""
            srun julia --project=${JULIAPROJ} -e "include(\"${CYLC_WORKFLOW_RUN_DIR}/bin/BG_cylc/src/GetTopNet.jl\"); GetInjectionXY(ARGS[1],ARGS[2],outfolder=ARGS[3])" ${TOPNETFOLDER}/ ${INJECTION} ${CYLC_WORKFLOW_RUN_DIR}/
        """

    [[Get_EVA_XY]]
       inherit = Maui_Anc_JULIA

        script="""
        srun julia --project=${JULIAPROJ} -e "include(\"${CYLC_WORKFLOW_RUN_DIR}/bin/BG_cylc/src/GetTopNet.jl\"); GetInjectionXY(ARGS[1],ARGS[2],outfolder=ARGS[3], outfile=ARGS[4])" ${TOPNETFOLDER}/ ${CYLC_WORKFLOW_RUN_DIR}/EVA_rids.txt ${CYLC_WORKFLOW_RUN_DIR}/ EVA_XY.txt

        """


    [[proj_injection]]
        inherit = Maui_Anc_GMT

        script="""
            #ogr2ogr -f "OGR_GMT" ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt ${DOMAIN}
            #grep @D ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt | sed 's/# @D//g' | awk 'BEGIN{FS=",";RS="|"}{if(NR==5){print($0)}}' | awk 'BEGIN{RS=","}{print($1)}' >  ${INJECTION}

            #srun julia --project=${JULIAPROJ} -e "using BG_cylc; GetInjectionXY(ARGS[1],ARGS[2],outfolder=ARGS[3])" ${TOPNETSTREAMQ} ${INJECTION} ${CYLC_WORKFLOW_RUN_DIR}/

            gmt mapproject -Jt173/0/1:1 -C1600000/10000000 --PROJ_ELLIPSOID=GRS-80 --PROJ_SCALE_FACTOR=0.9996 -F -R170/180/-50/-30 ${CYLC_WORKFLOW_RUN_DIR}/Injection_XY.txt -i1,2,0,3 -o2,0,1,3 | awk '{printf("%d,%2.2f,%2.2f,rid_%s\n",$1,$2,$3,$4)}' > ${INJECTION}

            #rm ${INJECTION}
            #cp ${CYLC_WORKFLOW_RUN_DIR}/Injection_XY.txt ${INJECTION}
        """


    [[proj_EVA]]
        inherit = Maui_Anc_GMT

        script="""
            gmt mapproject -Jt173/0/1:1 -C1600000/10000000 --PROJ_ELLIPSOID=GRS-80 --PROJ_SCALE_FACTOR=0.9996 -F -R170/180/-50/-30 ${CYLC_WORKFLOW_RUN_DIR}/EVA_XY.txt -i1,2,0,3 -o2,0,1,3 | awk '{printf("%d,%2.2f,%2.2f,rid_%s\n",$1,$2,$3,$4)}' > ${CYLC_WORKFLOW_RUN_DIR}/EVA_XY_proj.txt
        """


    [[make_injection]]
        inherit = Maui_Anc_JULIA

        script ="""

               julia --project=${JULIAPROJ} -e "include(\"${CYLC_WORKFLOW_RUN_DIR}/bin/BG_cylc/src/GetTopNet.jl\"); GetTopNetPeakref(ARGS[1],ARGS[2],ARGS[3])" ${TOPNETFOLDER}/ ${CYLC_WORKFLOW_RUN_DIR}/oceanrids.txt ${CYLC_WORKFLOW_RUN_DIR}/reftime.txt



               julia --project=${JULIAPROJ} -e "include(\"${CYLC_WORKFLOW_RUN_DIR}/bin/BG_cylc/src/GetTopNet.jl\"); GetTopNetFlow(ARGS[1],ARGS[2],outfolder=ARGS[3])" ${TOPNETFOLDER}/ ${INJECTION} ${CYLC_WORKFLOW_RUN_DIR}/
        """



    [[prep_tide_old]]
        inherit = Maui_Anc_JULIA

        script ="""
           #LON=`awk '{if(NR==14){print($1)}}' $INFOFILE`
           #LAT=`awk '{if(NR==14){print($2)}}' $INFOFILE`


	       srun julia --project=${JULIAPROJ} -e "include(\"${CYLC_WORKFLOW_RUN_DIR}/bin/BG_cylc/src/gettide.jl\"); predictNZtides(parse(Float64, ARGS[1]),parse(Float64,ARGS[2]),ARGS[3],tidemodelfile=ARGS[4])" ${NZTMX} ${NZTMY} ${CYLC_WORKFLOW_RUN_DIR}/tide_TMP.txt ${TIDESURF}
        """

        [[[directives]]]
             --mem=16GB


    [[prep_tidebnd]]
        inherit = Maui_Anc_GMT

        script="""
            # Only do the tide for non-landlocked domain. Landlocked domain have Outlet_rids.txt
            if [ -s ${CYLC_WORKFLOW_RUN_DIR}/Outlet_rids.txt ]; then
             echo "This is a Landlock domain"
             cat ${CYLC_WORKFLOW_RUN_DIR}/Outlet_rids.txt
            else
            ogr2ogr -f "OGR_GMT" ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt ${BGFLOODDOMAIN}

            gmt gmtspatial -Q ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt > polysize.tmp

            idlargestpoly=`awk 'BEGIN{maxsize=0; LP=0;}{if($3>maxsize){maxsize=$3; LP=NR}}END{printf("%d",LP)}' polysize.tmp`

            awk -v polyid=$idlargestpoly 'BEGIN{ispoly=0;thispoly=0}{if($1!="#"){if($1==">"){thispoly=thispoly+1; if(thispoly==polyid){ispoly=1}else{ispoly=0}}else{if(ispoly==1){print($0)}}}}' ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt  > ${CYLC_WORKFLOW_RUN_DIR}/aoi_BGFLOOD.txt


            gmt sample1d -Fl -T100.0c ${CYLC_WORKFLOW_RUN_DIR}/aoi_BGFLOOD.txt | gmt grdtrack -G${DEMFILE}?z | awk '{if($1!=">"){if($3<-1.0){print($1,$2,$3)}}}' | gmt gmtspatial -i0,1 -Sb1064 | gmt gmtspatial -R${DEMFILE}?z -C > ${CYLC_WORKFLOW_RUN_DIR}/tidebnd_tmp.bnd

            # Cyp added this to avoid issues when NaNs are generated in the process above
            awk 'BEGIN{nandetected=0}{if($1=="NaN"){nandetected=1};if(nandetected==0){print($0)}else{}}' ${CYLC_WORKFLOW_RUN_DIR}/tidebnd_tmp.bnd > ${TIDEBDNPOLY}

            gmt gmtinfo -Ib10 -Ve ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt | gmt grdtrack -G${DEMFILE} | gmt gmtinfo -El2 -o0,1 > ${CYLC_WORKFLOW_RUN_DIR}/tideinfo.txt
            fi

        """

    [[prep_tide]]
        inherit = Maui_Anc_JULIA

        script ="""
            # Only do the tide for non-landlocked domain. Landlocked domain have Outlet_rids.txt
           if [ -s ${CYLC_WORKFLOW_RUN_DIR}/Outlet_rids.txt ]; then
                echo "This is a Landlock domain"
                cat ${CYLC_WORKFLOW_RUN_DIR}/Outlet_rids.txt
           else
                REG=`awk '{if(NR==1){print($1)}}' $INFOFILE`
                NZTMX=`awk '{if(NR==1){print($1)}}' ${CYLC_WORKFLOW_RUN_DIR}/tideinfo.txt`
                NZTMY=`awk '{if(NR==1){print($2)}}' ${CYLC_WORKFLOW_RUN_DIR}/tideinfo.txt`
                LAT=`awk '{if(NR==13){print($2)}}' $INFOFILE`

                #REFTIME=`julia --project=${JULIAPROJ} -e "include(\"${CYLC_WORKFLOW_RUN_DIR}/bin/BG_cylc/src/GetTopNet.jl\"); GetTopNetPeakref(ARGS[1],ARGS[2])" ${TOPNETFOLDER}/ ${CYLC_WORKFLOW_RUN_DIR}/oceanrids.txt`
                REFTIME=`awk '{if(NR==1){print($0)}}' ${CYLC_WORKFLOW_RUN_DIR}/reftime.txt`
                echo ${REFTIME}

                #echo "${REG} ${NZTMX} ${NZTMY} ${TIDEFILE} ${TIDESURF} ${LAT}"
                julia --project=${JULIAPROJ} -e "include(\"${CYLC_WORKFLOW_RUN_DIR}/bin/BG_cylc/src/gettide.jl\"); predictMaptide(parsetuple(ARGS[1]),500.0,parse(Float64,ARGS[2]),parse(Float64,ARGS[3]),ARGS[4],tidemodelfile=ARGS[5],reflat=parse(Float64,ARGS[6]),reftimestr=ARGS[7])" ${REG} ${NZTMX} ${NZTMY} ${TIDEFILE} ${TIDESURF} ${LAT} ${REFTIME}
            fi
        """

        [[[directives]]]
             --mem=16GB


    [[synch_tide]]
        inherit = Python_conda
        script = """
               #python ${PYTHONPATH}phase_tide_max_flood.py ${TOPNETFOLDER} ${CYLC_WORKFLOW_RUN_DIR}/oceanrids.txt ${CYLC_WORKFLOW_RUN_DIR}/tide_TMP.txt $TIDEFILE $INFOFILE
         """

	[[prep_lake]]
		         inherit = Maui_Anc_JULIA

		         script ="""
		             # Only do the tide for non-landlocked domain. Landlocked domain have Outlet_rids.txt
		             #echo "${REG} ${NZTMX} ${NZTMY} ${TIDEFILE} ${TIDESURF} ${LAT}"
                     REG=`awk '{if(NR==1){print($1)}}' $INFOFILE`
		             julia --project=${JULIAPROJ} -e "include(\"${CYLC_WORKFLOW_RUN_DIR}/bin/BG_cylc/src/GetLake.jl\"); extractLakes(parsetuple(ARGS[1]),ARGS[2],infofile=ARGS[3],outfolder=ARGS[4])" ${REG} ${LAKEFILE} ${CYLC_WORKFLOW_RUN_DIR}/mylakes.txt ${CYLC_WORKFLOW_RUN_DIR}/
		           
		         """

    [[prep_lake_bnd]]
                inherit = Maui_Anc_GMT

                script = """
                file=${CYLC_WORKFLOW_RUN_DIR}/mylakes.txt

                gmt grdmath ${DEMFILE}?z 0 MUL -1 ADD = ${CYLC_WORKFLOW_RUN_DIR}/hotstartlake.nc?zs

                while IFS= read -r item; do
                    echo "Processing: $item"
                    ogr2ogr -f "OGR_GMT" ${CYLC_WORKFLOW_RUN_DIR}/${item}.gmt ${CYLC_WORKFLOW_RUN_DIR}/${item}".geojson"
#
                    gmt grdtrack ${CYLC_WORKFLOW_RUN_DIR}/${item}.gmt -G${DEMFILE}?z -Z | awk '{printf("%f\t%f\t%2.1f\n",0.5,0.5,$1)}' | gmt blockmode -R0/1/0/1 -I0.5 -o2 | awk '{printf("0.0\t%f\n3600000.0\t%f\n",$1,$1)}' > ${CYLC_WORKFLOW_RUN_DIR}/${item}.bnd

                    awk '{if($1!="#" && $1!=">"){printf("%f\t%f\n",$1,$2)}}' ${CYLC_WORKFLOW_RUN_DIR}/${item}.gmt > ${CYLC_WORKFLOW_RUN_DIR}/${item}_poly.txt

                    LAKELEVEL=`awk '{if(NR==1){printf("%f",$2)}}' ${CYLC_WORKFLOW_RUN_DIR}/${item}.bnd`

                   gmt grdmask -R${CYLC_WORKFLOW_RUN_DIR}/hotstartlake.nc ${CYLC_WORKFLOW_RUN_DIR}/${item}.gmt -NNaN/${LAKELEVEL}/${LAKELEVEL} -GlakeHST.nc

                    gmt grdmath lakeHST.nc ${CYLC_WORKFLOW_RUN_DIR}/hotstartlake.nc DENAN = tmplake.nc?zs

                    mv tmplake.nc ${CYLC_WORKFLOW_RUN_DIR}/hotstartlake.nc

                done < "$file"

                gmt grdmath ${CYLC_WORKFLOW_RUN_DIR}/hotstartlake.nc?zs ${DEMFILE}?z SUB 0 MAX = ${CYLC_WORKFLOW_RUN_DIR}/hotstartdepth.nc

                gmt grdmath ${CYLC_WORKFLOW_RUN_DIR}/hotstartdepth.nc 50 GT ${CYLC_WORKFLOW_RUN_DIR}/hotstartdepth.nc 50.0 SUB MUL ${DEMFILE}?z ADD = ${CYLC_WORKFLOW_RUN_DIR}/Filled_Lakes.nc?z
                
                # comment line below to leave DEM untouched
                mv ${CYLC_WORKFLOW_RUN_DIR}/Filled_Lakes.nc ${DEMFILE}

                """
        [[[directives]]]
             --mem=48GB
             --time=2:40:00

    [[Add_Lakes_BG_coarse]]
        inherit = Maui_Anc_GMT

                script = """
                file=${CYLC_WORKFLOW_RUN_DIR}/mylakes.txt

                printf "hotstartfile = %s\n" ${CYLC_WORKFLOW_RUN_DIR}/hotstartlake.nc >> ${OUTFOLDER}${BGPARAM_COARSE}


                while IFS= read -r item; do
                    #
                    printf "bndseg = %s,%s,3;\n" ${CYLC_WORKFLOW_RUN_DIR}/${item}_poly.txt ${CYLC_WORKFLOW_RUN_DIR}/${item}.bnd >> ${OUTFOLDER}${BGPARAM_COARSE}
                done < "$file"
                """

    [[Add_Lakes_BG_fine]]
        inherit = Maui_Anc_GMT

                script = """
                file=${CYLC_WORKFLOW_RUN_DIR}/mylakes.txt

                printf "hotstartfile = %s\n" ${CYLC_WORKFLOW_RUN_DIR}/hotstartlake.nc >> ${OUTFOLDER}${BGPARAM_THIN}


                while IFS= read -r item; do
                    #
                    printf "bndseg = %s,%s,3;\n" ${CYLC_WORKFLOW_RUN_DIR}/${item}_poly.txt ${CYLC_WORKFLOW_RUN_DIR}/${item}.bnd >> ${OUTFOLDER}${BGPARAM_THIN}

                    gmt grdmask -R${TARGETEV} ${CYLC_WORKFLOW_RUN_DIR}/${item}_poly.txt -N1/1/0 -G${CYLC_WORKFLOW_RUN_DIR}/${item}_outmask.nc

                    gmt grdmath ${CYLC_WORKFLOW_RUN_DIR}/${item}_outmask.nc ${TARGETEV} MUL = ${CYLC_WORKFLOW_RUN_DIR}/temp_target.nc

                    mv ${CYLC_WORKFLOW_RUN_DIR}/temp_target.nc ${TARGETEV}

                done < "$file"
                """


    [[prep_info]]
        inherit = Maui_Anc_GMT

        script = """

            ogr2ogr -f "OGR_GMT" ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt ${BGFLOODDOMAIN}

            gmt gmtspatial -Q ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt > polysize.tmp

            idlargestpoly=`awk 'BEGIN{maxsize=0; LP=0;}{if($3>maxsize){maxsize=$3; LP=NR}}END{printf("%d",LP)}' polysize.tmp`

            awk -v polyid=$idlargestpoly 'BEGIN{ispoly=0;thispoly=0}{if($1!="#"){if($1==">"){thispoly=thispoly+1; if(thispoly==polyid){ispoly=1}else{ispoly=0}}else{if(ispoly==1){print($0)}}}}' ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt  > ${CYLC_WORKFLOW_RUN_DIR}/aoi_BGFLOOD.txt


            #REFTIME=`awk '{if(NR==3){print($0)}}' ${CYLC_WORKFLOW_RUN_DIR}/reftime.txt`
			### Get domain's bounds from domain.gmt and correct the values to superimpose with the DEM's grid
            ##DEMFILE=${CYLC_WORKFLOW_RUN_DIR}/Elevation.nc

            XMINI=$(gmt gmtinfo -I10 -C -Ve ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt | awk '{printf("%2.2f\n",$1)}')
            XMAXI=$(gmt gmtinfo -I10 -C -Ve ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt | awk '{printf("%2.2f\n",$2)}')
            YMINI=$(gmt gmtinfo -I10 -C -Ve ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt | awk '{printf("%2.2f\n",$3)}')
            YMAXI=$(gmt gmtinfo -I10 -C -Ve ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt | awk '{printf("%2.2f\n",$4)}')

            XMIN_DEM=$(gmt grdinfo ${DEMFILE} | grep "x_min" | awk -F"x_min: | x_max: | x_inc: | name:" '{print $2}')
            DX_DEM=$(  gmt grdinfo ${DEMFILE} | grep "x_min" | awk -F"x_min: | x_max: | x_inc: | name:" '{print $4}')
            YMIN_DEM=$(gmt grdinfo ${DEMFILE} | grep "y_min" | awk -F"y_min: | y_max: | y_inc: | name:" '{print $2}')
            DY_DEM=$(  gmt grdinfo ${DEMFILE} | grep "y_min" | awk -F"y_min: | y_max: | y_inc: | name:" '{print $4}')

            XMIN=$(echo "$XMIN_DEM + ((($XMINI - $XMIN_DEM)/$DX_DEM)/1    )*$DX_DEM - $DX_DEM/2" | bc)
            XMAX=$(echo "$XMIN     + ((($XMAXI - $XMIN    )/$DX)/1 + 1)*$DX                    " | bc)
            YMIN=$(echo "$YMIN_DEM + ((($YMINI - $YMIN_DEM)/$DY_DEM)/1    )*$DY_DEM - $DY_DEM/2" | bc)
            YMAX=$(echo "$YMIN     + ((($YMAXI - $YMIN    )/$DX)/1 + 1)*$DX                    " | bc)

            REG="${XMIN}.0,${XMAX}.0,${YMIN}.0,${YMAX}.0"
			###

            ### Start creation info file
            if [ -f $INFOFILE ] # First check if file exist and delete it if so
            then
                rm $INFOFILE
            fi

#            gmt gmtinfo -I10 -C -Ve ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt | awk '{printf("%2.2f,%2.2f,%2.2f,%2.2f\n",$1,$2,$3,$4)}' > $INFOFILE
            echo ${REG} > $INFOFILE
            echo ${DX} >> $INFOFILE
            #echo $GEOFABRICFILE >> $INFOFILE
            echo ${DEMFILE} >> $INFOFILE
            #echo $ROUGHNESSFILE >> $INFOFILE
            echo ${CYLC_WORKFLOW_RUN_DIR}/Roughness.nc >> $INFOFILE
            echo  ${CYLC_WORKFLOW_RUN_DIR}/aoi_BGFLOOD.txt >> $INFOFILE
            printf "%s%s\n"  $RAINOUT ?depth >> $INFOFILE
            echo $INJECTION >> $INFOFILE
            echo $INJECTIONFOLDER >> $INFOFILE
            echo $LEVELS >> $INFOFILE
            echo $TARGETEV >> $INFOFILE
            echo $TIDEFILE >> $INFOFILE
            echo $BGOUTFILE >> $INFOFILE


            # Get lon lat from deepest corner
            gmt gmtinfo -Ib10 -Ve ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt | gmt grdtrack -G${DEMFILE} | gmt gmtinfo -El2 -o0,1 | gmt mapproject -Jt173/0/1:1 -C1600000/10000000 --PROJ_ELLIPSOID=GRS-80 --PROJ_SCALE_FACTOR=0.9996 -F -R170/180/-50/-30 -I >> $INFOFILE
            #  gmt mapproject -Jt173/0/1:1 -C1600000/10000000 --PROJ_ELLIPSOID=GRS-80 --PROJ_SCALE_FACTOR=0.9996 -F -R170/180/-50/-30
            #gmt gmtinfo -Ib10 -Ve ${CYLC_WORKFLOW_RUN_DIR}/domain.gmt |  gmt mapproject -Jt173/0/1:1 -C1600000/10000000 --PROJ_ELLIPSOID=GRS-80 --PROJ_SCALE_FACTOR=0.9996 -F -R170/180/-50/-30 -I | gmt gmtinfo -I0.001 -C >> $INFOFILE

            # Timepeak
            awk '{if(NR==1){print($0)}}' ${CYLC_WORKFLOW_RUN_DIR}/reftime.txt >> $INFOFILE

            # referencetime
            awk '{if(NR==3){print($0)}}' ${CYLC_WORKFLOW_RUN_DIR}/reftime.txt >> $INFOFILE
            awk '{if(NR==4){print($0)}}' ${CYLC_WORKFLOW_RUN_DIR}/reftime.txt >> $INFOFILE
            # Only do the tide for non-landlocked domain. Landlocked domain have Outlet_rids.txt
            if [ -s ${CYLC_WORKFLOW_RUN_DIR}/Outlet_rids.txt ]; then
                echo "" >> $INFOFILE
            else
                echo ${TIDEBDNPOLY} >> $INFOFILE
            fi

            # Init Sea level and Sea level rise
            echo ${ZS_INIT} >> $INFOFILE
            echo ${SLR} >> $INFOFILE


     """


    [[prep_param_coarse]]
        inherit = Maui_Anc_JULIA

        script ="""
               julia --project=${JULIAPROJ} -e "include(\"${CYLC_WORKFLOW_RUN_DIR}/bin/BG_cylc/src/makBGparam.jl\"); MakBGParam(ARGS[1],ARGS[2],coarse=true)" $INFOFILE ${OUTFOLDER}${BGPARAM_COARSE}
	       """

    [[prep_param_fine]]
        inherit = Maui_Anc_JULIA

        script ="""
                julia --project=${JULIAPROJ} -e "include(\"${CYLC_WORKFLOW_RUN_DIR}/bin/BG_cylc/src/makBGparam.jl\"); MakBGParam(ARGS[1],ARGS[2],coarse=false)" $INFOFILE ${OUTFOLDER}${BGPARAM_THIN}
	       """

  ## OLD version
  # [[prep_targetrefine]]
  #      inherit = Maui_Anc_GMT
  #
  #      script = """
  #
  #          #laststep=`ncdump -h ${BGOUTFILE} | grep "time =" |awk 'BEGIN{FS="("}{split($2,a," ");printf("%d",a[1]-1)}'`
  #          #gmt grdgradient ${BGOUTFILE}?zs_P0[1] -D -S${CYLC_WORKFLOW_RUN_DIR}/slopes.nc
  #          #gmt grdmath ${CYLC_WORKFLOW_RUN_DIR}/slopes.nc 0.1 LT ${BGOUTFILE}?hmax_P0[${laststep}] 0.1 GT MUL ${BGOUTFILE}?zs_P0[1] 0.01 GT MUL 0 DENAN 3 MUL = ${TARGETEV}
  #
  #          srun MakeTargetAdapt ${BGOUTFILE} ${GEOFABRICFILE} ${TARGETEV}
  #          """

    [[prep_targetrefine]]
        inherit = Python_conda

        script = """
            python ${PYTHONPATH}refinement.py ${BGOUTFILE}_coarse.nc ${STOPBANKS} {{inputs.OUTPUT_DIR}}/{{LOC}}/${GEOFABRIC_RESO}m_geofabric.nc ${DOMAINMASK} ${TARGETEV} ${OUTFOLDER}
        """
        [[[directives]]]
             --time=4:00:00
             --mem=48GB


    [[Check_Compile]]
        inherit = Maui_Anc_prepost

        script ="""
            localTag=$(<${CYLC_WORKFLOW_RUN_DIR}/bin/BG_Flood-version.txt)
            if [ {{inputs.GPU_SRC}} == 'Maui' ]; then
                compilehost='Maui'
            else
                compilehost='Mahuika'
            fi
            exec=${CYLC_WORKFLOW_RUN_DIR}/bin/BG_Flood_${compilehost}
            if [ ! -f $exec ] || [ {{inputs.BGFLOOD_TAG}} != $localTag ]; then
                echo "BG_Flood executable will be re-generated"
                cylc__job_abort "ERROR: BG_Flood executable not found or different version, the executable will be regenerated."
            else
                echo "Use of BG_Flood executable from repo"

            fi
        """

##BG_Flood run on Maui
    [[Compile_BG_Maui]]
        inherit = Maui_Anc_BG_Compile

        script ="""
            git clone --depth 1 --branch {{inputs.BGFLOOD_TAG}} https://github.com/CyprienBosserelle/BG_Flood.git
            cd ./BG_Flood/
            make
            cp BG_Flood ${CYLC_WORKFLOW_RUN_DIR}/bin/BG_Flood_Maui
        """
        [[[directives]]]
             --time=0:30:00

    [[Run_BG_coarse_Maui]]
        inherit = Maui_Anc_BG
        execution time limit = PT24H
        script ="""
            ${CYLC_WORKFLOW_RUN_DIR}/bin/BG_Flood_Maui ${OUTFOLDER}${BGPARAM_COARSE}
        """
        [[[directives]]]
             --time=24:00:00

    [[Run_BG_fine_Maui]]
