        [[[directives]]]
             --time=12:00:00 #4:00:00
             --account=niwa03440
             --partition = nesi_prepost
             --ntasks=1
             --cpus-per-task=1
             --mem=10GB


    [[CollapseBG]]
        inherit = Maui_Anc_JULIA

        script ="""
               srun julia --project=${JULIAPROJ} -e "include(\"$CYLC_WORKFLOW_RUN_DIR/bin/BG_cylc/src/CollapseBG.jl\"); WriteFlooding(ARGS[1],ARGS[2])" $BGOUTFILE.nc ${BGOUTFILE}_Floodmap
	       """
        [[[directives]]]
             --mem=40GB

    [[CreateTiff]]
        inherit = Maui_Anc_prepost
        env-script="""
            module load GDAL/3.2.3-GCC-7.1.0
            module load GMT/6.4.0-GCC-7.1.0
            """

        script ="""
               gmt grdconvert ${BGOUTFILE}_Floodmap_hmax.nc -GTemp_tiff.tif=gd:GTIFF
               gdal_translate -a_srs "EPSG:2193" Temp_tiff.tif ${BGOUTFILE}_Floodmap_hmax.tif
               gmt grdconvert ${BGOUTFILE}_Floodmap_zsmax.nc -GTemp_tiff.tif=gd:GTIFF
               gdal_translate -a_srs "EPSG:2193" Temp_tiff.tif ${BGOUTFILE}_Floodmap_zsmax.tif
               gmt grdconvert ${BGOUTFILE}_Floodmap_humax.nc -GTemp_tiff.tif=gd:GTIFF
               gdal_translate -a_srs "EPSG:2193" Temp_tiff.tif ${BGOUTFILE}_Floodmap_humax.tif
               gmt grdconvert ${BGOUTFILE}_Floodmap_umax.nc -GTemp_tiff.tif=gd:GTIFF
               gdal_translate -a_srs "EPSG:2193" Temp_tiff.tif ${BGOUTFILE}_Floodmap_umax.tif
               rm Temp_tiff.tif
        """

    [[HydroG_EVA]]
        inherit = Python_conda
        script ="""
               while IFS= read -r line; do
                    x=$(echo $line | cut -f2 -d,)
                    y=$(echo $line | cut -f3 -d,)
                    rid=$(echo $line | cut -f1 -d,)

                    echo "Extracting rid $rid, in location [$x $y]"
                    ncToTimeseries.sh ${BGOUTFILE}.nc $x $y EVA_TS_$rid.txt

                    python ${PYTHONPATH}Plot_HydroG.py ${CYLC_WORKFLOW_RUN_DIR} EVA_TS_$rid.txt EVA_TS_$rid.png ${LOCATION}_${MODEL_NAME}_EVA-$rid

               done < ${CYLC_WORKFLOW_RUN_DIR}/EVA_XY_proj.txt
               """

    [[Copy_Results]]
        inherit = Maui_Anc_prepost
        script="""
                if [ ! -d "$OUT_DIR/inputs" ]; then
                   myfolder=$(echo $OUT_DIR/inputs)
                   echo $myfolder
                   mkdir -p -m 2770 $myfolder
               fi

               # Copy logs
               cp -r $CYLC_WORKFLOW_RUN_DIR/log $OUT_DIR 2>/dev/null || :
               cp -r $CYLC_WORKFLOW_RUN_DIR/work $OUT_DIR 2>/dev/null || :

              # Copy select results
               cp $BGOUTFILE* $OUT_DIR
               cp $CYLC_WORKFLOW_RUN_DIR/rid_* $OUT_DIR/inputs 2>/dev/null || :
               cp $CYLC_WORKFLOW_RUN_DIR/BG_param* $OUT_DIR
               cp $CYLC_WORKFLOW_RUN_DIR/info.txt $OUT_DIR
               cp $CYLC_WORKFLOW_RUN_DIR/Elevation.nc $CYLC_WORKFLOW_RUN_DIR/aoi_BGFLOOD.txt $OUT_DIR/inputs
               cp $CYLC_WORKFLOW_RUN_DIR/Roughness.nc $OUT_DIR/inputs
               cp $CYLC_WORKFLOW_RUN_DIR/outputrain_test.nc $OUT_DIR/inputs
               cp $CYLC_WORKFLOW_RUN_DIR/Target_refine2.nc $OUT_DIR/inputs 2>/dev/null || :
               if [ ! -s ${CYLC_WORKFLOW_RUN_DIR}/Outlet_rids.txt ]; then
                   cp $CYLC_WORKFLOW_RUN_DIR/tide* $OUT_DIR/inputs
               fi
               cp $CYLC_WORKFLOW_RUN_DIR/*.png $OUT_DIR
               cp $CYLC_WORKFLOW_RUN_DIR/EVA_TS_* $OUT_DIR 2>/dev/null || :
               """

      [[copy_logs]]
        inherit = Maui_Anc_prepost
        script = """
            cp -rf $CYLC_WORKFLOW_RUN_DIR/log $OUT_DIR 2>/dev/null || :
            cp -r $CYLC_WORKFLOW_RUN_DIR/work $OUT_DIR 2>/dev/null || :
        """

      [[remove_lock]]
        inherit = Maui_Anc_prepost
        script="""
               if [ -f $LOCK_FILE ]; then rm $LOCK_FILE; fi
        """

      [[create_fail]]
        inherit = Maui_Anc_prepost
        script="""
            if [ -f $LOCK_FILE ]; then rm $LOCK_FILE; fi
            touch $FAIL_FILE
            echo ERROR: Created Failure file. Removed lock file.
            exit 1
        """
