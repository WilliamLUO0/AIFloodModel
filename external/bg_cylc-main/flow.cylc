#!Jinja2

{% import "inputs.j2" as inputs %}

{# set FILE_GPKG = FILE_GPKG | default("/nesi/project/niwa03440/catchments/Catchment_20230825.gpkg") #}
{% set LOC = LOCATION | default("Nuhaka") %}
{% set MODEL_DURATION = DURATION | default("12") %}
{% set MODEL_RETURNPERIOD = RETURNPERIOD | default("100") %}
{% set MODEL_TEMP = TEMP | default("0") %}
{% set SCENARIO = SCEN | default("100y_6h_0c") %}
{% set RUN_DIR = RUN_DIR | default("$CYLC_WORKFLOW_RUN_DIR") %}


[scheduling]
    cycling mode = integer
    initial cycle point = 1
    [[graph]]
        R1="""

            read_gpkg? => Get_injectionXY? => proj_injection? => make_injection? => prep_info?
            prep_info? => prep_rain? => prep_raintime?

            prep_elevation? => prep_info? => prep_tidebnd? => prep_tide? => synch_tide?

            prep_roughness? & prep_elevation? & prep_raintime? & prep_info? & synch_tide? => prep_param_coarse?

            prep_info? => prep_lake? => prep_lake_bnd?

            

            #Check_Compile:fail? => Compile_BG_{{inputs.GPU_SRC}}?
            #Check_Compile? | Compile_BG_{{inputs.GPU_SRC}}? => Run_BG_coarse_{{inputs.GPU_SRC}}?

            Compile_BG_{{inputs.GPU_SRC}}? => Run_BG_coarse_{{inputs.GPU_SRC}}?

            prep_param_coarse? & prep_lake_bnd? => Add_Lakes_BG_coarse? => Run_BG_coarse_{{inputs.GPU_SRC}}?
            Run_BG_coarse_{{inputs.GPU_SRC}}? => prep_targetrefine? & prep_param_fine? => Add_Lakes_BG_fine => Run_BG_fine_{{inputs.GPU_SRC}}?
            Run_BG_fine_{{inputs.GPU_SRC}}? => PlotFlood? & CollapseBG? => CreateTiff?
            Run_BG_fine_{{inputs.GPU_SRC}}? => Get_EVA_XY? => proj_EVA? => HydroG_EVA?

           

            #Run_BG_fine_{{inputs.GPU_SRC}}? => sanity_checks

            # Copy results and remove lock
            #CreateTiff? & HydroG_EVA? & sanity_checks? => Copy_Results => remove_lock
            CreateTiff? & HydroG_EVA? => Copy_Results => remove_lock

            # Write logs for any failure and create failure file
            read_gpkg:fail? | prep_rain:fail? | Get_injectionXY:fail? | proj_injection:fail? | make_injection:fail? | prep_info:fail? | prep_elevation:fail? | prep_tide:fail? | synch_tide:fail? | prep_roughness:fail? | prep_param_coarse:fail? | prep_param_fine:fail? | Run_BG_coarse_{{inputs.GPU_SRC}}:fail? | prep_targetrefine:fail? | Run_BG_fine_{{inputs.GPU_SRC}}:fail? | PlotFlood:fail? | CollapseBG:fail? | CreateTiff:fail? |  Get_EVA_XY:fail? | proj_EVA:fail? | HydroG_EVA:fail? => copy_logs
            copy_logs => create_fail
            """
[runtime]
    [[root]]
        [[[environment]]]
            LOCATION = {{LOC}}
            GEOFABRIC_RESO={{inputs.GEOFABRIC_RESOLUTION}}
            MODEL_NAME = {{SCENARIO}}
            RAININ = {{inputs.OUTPUT_DIR}}/{{LOC}}/${MODEL_NAME}/Design_Storm/${MODEL_NAME}_nztm.nc
            GEOFABRICFILE = {{inputs.OUTPUT_DIR}}/{{LOC}}/${GEOFABRIC_RESO}m_geofabric.nc
            {% if (inputs.DEMFILE is defined and inputs.DEMFILE != "") %}
                GEOFABRICFILE = {{inputs.OUTPUT_DIR}}/{{LOC}}/{{inputs.DEMFILE}}
            {% endif  %}
            ROUGHNESSFILE = {{inputs.OUTPUT_DIR}}/{{LOC}}/${GEOFABRIC_RESO}m_geofabric.nc?zo
            TOPNETFOLDER = {{inputs.OUTPUT_DIR}}/{{LOC}}/${MODEL_NAME}/TopNet
            GEOPACKAGE = {{inputs.FILE_GPKG}}
            TIDESURF = {{inputs.TIDESURF}}
            JULIADEPOT = {{inputs.JULIADEPOT}}
            STOPBANKS = {{inputs.STOPBANKS}}

			LAKEFILE = {{inputs.LAKEFILE}}

            DOMAIN=${CYLC_WORKFLOW_RUN_DIR}/domain.geojson
            DOMAINMASK=${CYLC_WORKFLOW_RUN_DIR}/domainmask.geojson
            RAINMASK=${CYLC_WORKFLOW_RUN_DIR}/rainmask.geojson
            BGFLOODDOMAIN=${CYLC_WORKFLOW_RUN_DIR}/flooddomain.geojson

            RAINOUT = ${CYLC_WORKFLOW_RUN_DIR}/outputrain_test.nc
            TIDEFILE = ${CYLC_WORKFLOW_RUN_DIR}/tidebnd.nc
            TIDEBDNPOLY = ${CYLC_WORKFLOW_RUN_DIR}/tidebndpoly.bnd
            INFOFILE = ${CYLC_WORKFLOW_RUN_DIR}/info.txt
            DEMFILE=${CYLC_WORKFLOW_RUN_DIR}/Elevation.nc

            INJECTION = ${CYLC_WORKFLOW_RUN_DIR}/InjectPoints.txt
            INJECTIONFOLDER = ${CYLC_WORKFLOW_RUN_DIR}/

            DX = 64
            LEVELS = 0,3,0

            ZS_INIT = -1.0
            {% if (inputs.SLR is defined and inputs.SLR != "") %}
                SLR = {{inputs.SLR}}
            {% else %}
                SLR = 0.0
            {% endif  %}



            #Change to 0,4,0 if reso is 4m
            {% if inputs.GEOFABRIC_RESOLUTION == 4 %}
                LEVELS = 0,4,0
            {% endif %}
            TARGETEV = ${CYLC_WORKFLOW_RUN_DIR}/Target_refine2.nc
            BGPARAM_COARSE = BG_param_coarse.txt
            BGPARAM_THIN = BG_param_thin.txt
            OUTFOLDER = ${CYLC_WORKFLOW_RUN_DIR}/
            # No .nc in the output name below only root name the .nc gets added in MakBGparam.jl
            BGOUTFILE = ${CYLC_WORKFLOW_RUN_DIR}/${LOCATION}_${MODEL_NAME}_Inundation
			JULIAPROJ=${CYLC_WORKFLOW_RUN_DIR}/bin/BG_cylc/
            PYTHONPATH=${CYLC_WORKFLOW_RUN_DIR}/lib/python/

            LOCK_FILE = {{inputs.OUTPUT_DIR}}/{{LOC}}/$MODEL_NAME//BG_Flood/bgflood.lock
            FAIL_FILE = {{inputs.OUTPUT_DIR}}/{{LOC}}/$MODEL_NAME/BG_Flood/bgflood.failure
            OUT_DIR = {{inputs.OUTPUT_DIR}}/{{LOC}}/$MODEL_NAME/BG_Flood
            TMPDIR = /nesi/nobackup/{{inputs.SLURM_JOB_ACC_ID}}/$USER

     [[Maui_Anc_prepost]]
        platform=maui-cs-slurm
        [[[directives]]]
             --time=0:40:00
             --account=niwa03440
             --partition=nesi_prepost
             #--gpus-per-node=1
             #--partition=nesi_research
             --ntasks=1
             --cpus-per-task=1
             --mem=8GB

        #[[meta]] = Maui preprocessing setup

     [[Maui_Anc_GMT]]
        inherit = Maui_Anc_prepost
        pre-script="""
            module load GMT/6.4.0-GCC-7.1.0
        """

     [[Maui_Anc_JULIA]]
        inherit = Maui_Anc_prepost
        pre-script="""
            module load Julia/1.7.1-GCC-9.2.0-VTune
            export JULIA_DEPOT_PATH=${JULIADEPOT}
        """

     [[Maui_Anc_BG]]
       platform = maui-cs-slurm
       env-script="""
            module load netCDF/4.7.4-GCC-9.2.0
            module load CUDA/11.4.1
            #module load CUDA/11.4.1
            #module load netCDF-C++4/4.3.0-GCC-7.1.0
        """
        [[[directives]]]
             --account=niwa03440
             --gpus-per-node=1
             --partition=nesi_gpu
             --ntasks=1
             --cpus-per-task=1
             --mem=32GB

        [[Maui_Anc_BG_visu]]
       platform = maui-cs-slurm
       env-script="""
            module load netCDF/4.7.4-GCC-9.2.0
            module load CUDA/11.4.1
            #module load CUDA/11.4.1
            #module load netCDF-C++4/4.3.0-GCC-7.1.0
        """
        [[[directives]]]
             --account=niwa03440
             --gpus-per-node=1
             --partition=niwa_work
             --ntasks=1
             --cpus-per-task=1
             --mem=32GB
             --nodelist=vgpuwsg002,vgpuwsg003

     [[Maui_Anc_BG_Compile]]
       inherit = Maui_Anc_prepost
       env-script="""
            module load netCDF/4.7.4-GCC-9.2.0
            module load CUDA/11.4.1
            #module load CUDA/11.4.1
            #module load netCDF-C++4/4.3.0-GCC-7.1.0
        """

     [[Mahuika_BG]]
       platform = mahuika-slurm
       env-script="""
            module load netCDF-C++4/4.3.1-gimpi-2020a
            module load CUDA/11.4.1
       """
       [[[directives]]]
             --account=niwa03440
             --gpus-per-node=A100:1
             --partition=hgx
             --ntasks=1
             --cpus-per-task=2
             --mem=80GB

     [[Mahuika_BG_Compile]]
       platform = mahuika-slurm
       env-script="""
            module load netCDF-C++4/4.3.1-gimpi-2020a
            module load CUDA/11.4.1
       """
       [[[directives]]]
             --time=0:40:00
             --account=niwa03440
             --mem-per-cpu=4096
             --ntasks=1
             --cpus-per-task=1

     [[Milan_BG]]
       platform = maui-cs-slurm
       env-script="""
            export PATH=/opt/nesi/CS400_centos7_bdw/XALT/current/bin:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/nvvm/bin:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/bin:/opt/nesi/CS400_centos7_bdw/netCDF/4.7.3-gimpi-2020a/bin:/opt/nesi/CS400_centos7_bdw/PCRE/8.43-GCCcore-9.2.0/bin:/opt/nesi/CS400_centos7_bdw/cURL/7.64.0-GCCcore-9.2.0/bin:/opt/nesi/CS400_centos7_bdw/HDF5/1.10.5-gimpi-2020a/bin:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/libfabric/bin:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/bin:/opt/nesi/CS400_centos7_bdw/binutils/2.32-GCCcore-9.2.0/bin:/opt/nesi/CS400_centos7_bdw/GCCcore/9.2.0/bin:$PATH
            export LD_LIBRARY_PATH=/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/nvvm/lib64:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/extras/CUPTI/lib64:/opt/nesi/CS400_centos7_bdw/CUDA/11.2.0/lib64:/opt/nesi/CS400_centos7_bdw/netCDF/4.7.3-gimpi-2020a/lib64:/opt/nesi/CS400_centos7_bdw/PCRE/8.43-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/cURL/7.64.0-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/HDF5/1.10.5-gimpi-2020a/lib:/opt/nesi/CS400_centos7_bdw/Szip/2.1.1-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/libfabric/lib:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/lib:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/lib/release:/opt/nesi/CS400_centos7_bdw/impi/2019.6.166-GCC-9.2.0/intel64/lib/release_mt:/opt/nesi/CS400_centos7_bdw/binutils/2.32-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/zlib/1.2.11-GCCcore-9.2.0/lib:/opt/nesi/CS400_centos7_bdw/GCCcore/9.2.0/lib64:/opt/nesi/CS400_centos7_bdw/GCCcore/9.2.0/lib

       """
