             #done

             # Plot histograms
             #if [[ -f ${OUTFOLDER}sanity_checks/log.out ]]; then
             #   rm ${OUTFOLDER}sanity_checks/log.out
             #fi
             #printf "0\n0\n0\n2\n$v1\n$out1\n$v2\n$out2\n" > ${OUTFOLDER}sanity_checks/sanity_checks_input.txt
             #while [[ -f ${OUTFOLDER}sanity_checks/sanity_checks_input.txt ]];
             #do
             #  python ${CYLC_WORKFLOW_RUN_DIR}/bin/sanity_checks.py ${CYLC_WORKFLOW_RUN_DIR}/BGout.nc ${CYLC_WORKFLOW_RUN_DIR}/BGout_1.nc ${GEOFABRICFILE} ${OUTFOLDER}sanity_checks/sanity_checks_input.txt ${OUTFOLDER}sanity_checks 0 1 0
             #done

             # Plot outliers
             #if [[ -f ${OUTFOLDER}sanity_checks/log.out ]]; then
             #   rm ${OUTFOLDER}sanity_checks/log.out
             #fi
             #printf "0\n0\n0\n2\n${v1}\n${out1}\n${v2}\n${out2}\n" > ${OUTFOLDER}sanity_checks/sanity_checks_input.txt
             #while [[ -f ${OUTFOLDER}sanity_checks/sanity_checks_input.txt ]];
             #do
             #     python ${CYLC_WORKFLOW_RUN_DIR}/bin/sanity_checks.py ${CYLC_WORKFLOW_RUN_DIR}/BGout.nc ${CYLC_WORKFLOW_RUN_DIR}/BGout_1.nc ${GEOFABRICFILE} ${OUTFOLDER}sanity_checks/sanity_checks_input.txt ${OUTFOLDER}sanity_checks 0 0 1
             #done

             # Clean
